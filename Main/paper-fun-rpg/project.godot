;   param=value ; assign values to parameters

config_version=5

[application]

config/name="PaperFunRPG"
run/main_scene="uid://dbf52ccu3mo7p"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://Images/icon.svg"

[autoload]

Master="*uid://b7lgqf7st0lb0"
BattleManager="*uid://ddncruxhyd0dt"
DisplayModeManager="*uid://d2wtbf4ncpmod"
SettingsManager="*uid://cbri01xi53366"
LoadingScreenData="*uid://dw41qtwjwju56"
AI="*uid://df1ess1luyd3d"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=2
window/stretch/mode="viewport"

[file_customization]

folder_colors={
"res://Dimensions/": "pink",
"res://Images/": "yellow",
"res://Music/": "purple",
"res://NPCs/": "green",
"res://Player/": "blue",
"res://Tests/": "gray",
"res://Tilemaps/": "orange",
"res://UI/": "red"
}

